{
  "manifest_version": 3,
  "name": "Script Test 2",
  "version": "1.0.0",
  "description": "Test with AI Translator format",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "test-bg.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["test-simple.js"],
      "css": ["test-style.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "test-popup.html"
  }
}
